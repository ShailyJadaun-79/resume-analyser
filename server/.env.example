# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27018/resumeai

# Authentication & Security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Google OAuth (for future social authentication)
GOOGLE_CLIENT_ID=your_google_client_id

# Cloudinary Configuration (for profile picture uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI Service Configuration
GEMINI_API_KEY=your_gemini_api_key

# Email configuration (for forgot password/email verification)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@resumeai.com

# Database Seeding Credentials
SEED_ADMIN_EMAIL=admin@resumeai.com
SEED_ADMIN_PASSWORD=AdminPassword123
